---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { Button } from '../../components/ui/button';
import supplierTypes from '../../../data/supplier-types.json';

const suppliers = Object.values(supplierTypes);
---

<Layout
  title="For Suppliers — Outsourced sustainability reporting | Emify"
  description="Farmers and small businesses supplying large customers face routine sustainability data requests. Emify handles every request for a fixed monthly fee — no demos, no per-report charges."
>
  <Navbar client:load />
  <main>
    <section class="py-16 sm:py-24 gradient-hero border-b">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="inline-flex items-center rounded-full bg-primary/10 border border-primary/20 px-3 py-1 text-xs font-semibold text-primary mb-6">
          For Suppliers
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 max-w-3xl text-balance">
          Your large customers are asking for sustainability data. We handle every request — for a fixed monthly fee.
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mb-8">
          From FY26 the next group of Australian companies must report mandatory climate disclosures. They need data from their suppliers — and they're already asking. Whether you supply Coles, BHP, a university, a hospital or a council, Emify takes those data requests off your desk and answers them on your behalf.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/for-suppliers/signup" data-track="cta-click">
            <button class="bg-primary text-primary-foreground hover:bg-primary/90 h-11 rounded-md px-8 inline-flex items-center justify-center text-sm font-medium">
              Get started
            </button>
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24" data-ab-section>
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-3">Pick your situation</h2>
        <p class="text-base text-muted-foreground mb-10 max-w-2xl">
          Each supplier type has slightly different data its buyers ask for. Pick yours below and we'll show you exactly what we handle.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {suppliers.map((s: any) => (
            <a
              href={`/for-suppliers/${s.slug}`}
              class="group rounded-xl border bg-card p-6 hover:border-primary/40 hover:shadow-md transition"
            >
              <h3 class="text-base font-bold text-foreground mb-2 group-hover:text-primary transition">{s.name}</h3>
              <p class="text-sm text-muted-foreground line-clamp-3 mb-4">{s.sub}</p>
              <div class="text-xs font-medium text-primary">{s.fixedPriceFrom} →</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-muted/30 border-t">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground mb-4">How it works</h2>
        <p class="text-base text-muted-foreground mb-10">Three things happen after you sign up:</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 text-left">
          <div class="rounded-xl border bg-card p-5">
            <div class="text-xs font-bold text-primary mb-2">STEP 1</div>
            <p class="text-sm text-foreground">You forward us any sustainability data request your customers send you — by email, supplier portal or PDF.</p>
          </div>
          <div class="rounded-xl border bg-card p-5">
            <div class="text-xs font-bold text-primary mb-2">STEP 2</div>
            <p class="text-sm text-foreground">We connect to your existing systems (accounting, farm management, ERP), pull the data, and prepare the response.</p>
          </div>
          <div class="rounded-xl border bg-card p-5">
            <div class="text-xs font-bold text-primary mb-2">STEP 3</div>
            <p class="text-sm text-foreground">You approve the response by email. We submit it through your customer's portal and keep the evidence on file for any audit.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer client:load />
</Layout>
