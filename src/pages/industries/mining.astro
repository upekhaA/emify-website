---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import IndustryPage from '../../components/IndustryPage';

const data = {
  industry: "Mining & Resources",
  h1: "NGER, Safeguard and Scope 3 for Australian mining — automated.",
  sub: "Mining companies face the most complex sustainability reporting stack in Australia: NGER facility reporting, Safeguard Mechanism baseline management, downstream Scope 3 from commodity sales, and increasingly, AASB S2 climate disclosures. Emify handles all of it from your existing operational systems.",
  integrations: ["SAP S/4HANA", "Pronto Xi", "Maximo", "Wenco", "XERO", "Mining2"],
  capabilities: [
    "NGER facility boundary mapping and Method 1–4 selection per activity type",
    "Safeguard baseline tracking with production-variable recalculation and SMC/ACCU modelling",
    "Scope 3 Category 11 (use of sold products) for coal, iron ore and lithium — downstream emissions",
    "Site-level emissions heatmap across multi-site operations",
    "Tailings storage facility (TSF) emissions quantification",
    "Methane monitoring and fugitive emissions from underground and open-cut operations",
    "AASB S2 climate risk disclosures — physical risk (flooding, temperature) and transition risk (carbon price)",
    "Assurance-ready evidence pack for CER and ASIC scrutiny",
  ],
  frameworks: ["NGER", "Safeguard", "AASB S2", "GHG Protocol", "ICMM", "GRI"],
  highlight: "One ASX-listed mining company used Emify to consolidate NGER reporting across 11 facilities, cutting their annual reporting workload from 14 weeks to 3 — and surfacing A$2.3m in previously unidentified Safeguard headroom.",
};
---

<Layout title="Mining & Resources — Emify" description="NGER, Safeguard Mechanism, Scope 3 and AASB S2 for Australian mining companies.">
  <Navbar client:load />
  <main><IndustryPage data={data} client:load /></main>
  <Footer client:load />
</Layout>
