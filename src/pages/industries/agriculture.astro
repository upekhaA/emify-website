---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import IndustryPage from '../../components/IndustryPage';

const data = {
  industry: "Agriculture",
  h1: "NGER agricultural methods, MLA emission factors and ACCU opportunities — automated.",
  sub: "Australian agribusinesses face a growing sustainability reporting burden: NGER agricultural method selection, livestock emission calculations using MLA-approved factors, Scope 3 from downstream processing, and now AASB S2 for larger operators. Emify brings together farm management system data with verified emission factors to produce compliant, auditable reports.",
  integrations: ["AgriWebb", "Agworld", "FarmLogs", "Xero", "MYOB", "Figured"],
  capabilities: [
    "NGER agricultural method selection (livestock, cropping, horticulture) with automatic factor updates",
    "MLA-approved emission factors for cattle, sheep and pigs — updated with latest research",
    "Soil carbon and vegetation sequestration modelling for ACCU opportunity identification",
    "Scope 3 Category 1 (purchased goods) and Category 11 (processing of sold products)",
    "Fertiliser and fuel consumption emissions from farm management system integration",
    "ACCU overlap analysis — identify eligible methodologies across your land portfolio",
    "AASB S2 physical risk assessment for drought, flood and heat stress by property",
  ],
  frameworks: ["NGER", "AASB S2", "GHG Protocol", "GRI", "ACCU"],
  highlight: "A diversified agricultural group used Emify across 120,000 hectares of mixed enterprise farming to identify A$1.4m in potential ACCU revenue from eligible vegetation and soil carbon activities — previously invisible in their reporting data.",
};
---

<Layout title="Agriculture — Emify" description="NGER agricultural methods, MLA factors, ACCU identification and AASB S2 for Australian agribusiness.">
  <Navbar client:load />
  <main><IndustryPage data={data} client:load /></main>
  <Footer client:load />
</Layout>
