---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import states from '../../../data/australian-states.json';

const stateList = Object.values(states);
---

<Layout
  title="Locations across Australia — Emify"
  description="Sustainability reporting services for businesses across every Australian state and region. Browse by location to see local regulatory and industry context."
>
  <Navbar client:load />
  <main>
    <section class="py-16 sm:py-24 gradient-hero border-b">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="inline-flex items-center rounded-full bg-primary/10 border border-primary/20 px-3 py-1 text-xs font-semibold text-primary mb-6">
          Locations
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 max-w-3xl text-balance">
          Sustainability reporting for businesses across Australia.
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mb-8">
          Emify serves businesses in every Australian state and territory. Each state has its own environment regulator, procurement framework and industry mix — and your obligations and opportunities differ accordingly.
        </p>
      </div>
    </section>

    <section class="py-16 sm:py-24" data-ab-section>
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <h2 class="text-2xl font-bold text-foreground mb-8">Browse by state or territory</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {stateList.map((s: any) => (
            <a
              href={`/locations/${s.slug}`}
              class="group rounded-xl border bg-card p-6 hover:border-primary/40 hover:shadow-md transition"
            >
              <div class="text-xs font-bold text-primary mb-2">{s.code}</div>
              <h3 class="text-lg font-bold text-foreground mb-2 group-hover:text-primary transition">{s.name}</h3>
              <p class="text-sm text-muted-foreground line-clamp-3">{s.industryMix}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer client:load />
</Layout>
