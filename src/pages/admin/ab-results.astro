---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const KEY = "emify_admin_2026";
const url = new URL(Astro.request.url);

if (url.searchParams.get("key") !== KEY) {
  return new Response("Unauthorised", { status: 401 });
}

// --- Read all events from KV ---
interface ABEvent {
  variant: "A" | "B";
  sessionId: string;
  event: "pageview" | "scroll_depth" | "cta_click";
  path: string;
  timestamp: number;
}

interface VariantStats {
  sessions: Set<string>;
  scrollDepth: Set<string>;
  ctaClicks: Set<string>;
}

const stats: Record<"A" | "B", VariantStats> = {
  A: { sessions: new Set(), scrollDepth: new Set(), ctaClicks: new Set() },
  B: { sessions: new Set(), scrollDepth: new Set(), ctaClicks: new Set() },
};

const kv = Astro.locals.runtime?.env?.EMIFY_AB_EVENTS;
let kvAvailable = !!kv;

if (kv) {
  let cursor: string | undefined;
  do {
    const result = await kv.list({ cursor, limit: 1000 });
    const values = await Promise.all(result.keys.map((k) => kv.get(k.name)));
    for (const raw of values) {
      if (!raw) continue;
      try {
        const ev: ABEvent = JSON.parse(raw);
        const v = ev.variant as "A" | "B";
        if (v !== "A" && v !== "B") continue;
        if (ev.event === "pageview") stats[v].sessions.add(ev.sessionId);
        if (ev.event === "scroll_depth") stats[v].scrollDepth.add(ev.sessionId);
        if (ev.event === "cta_click") stats[v].ctaClicks.add(ev.sessionId);
      } catch {}
    }
    cursor = result.list_complete ? undefined : result.cursor;
  } while (cursor);
}

function pct(num: number, den: number) {
  if (den === 0) return "—";
  return (num / den * 100).toFixed(1) + "%";
}

const aVisitors = stats.A.sessions.size;
const bVisitors = stats.B.sessions.size;
const aScroll = stats.A.scrollDepth.size;
const bScroll = stats.B.scrollDepth.size;
const aCTA = stats.A.ctaClicks.size;
const bCTA = stats.B.ctaClicks.size;
const aConv = aVisitors > 0 ? aCTA / aVisitors : 0;
const bConv = bVisitors > 0 ? bCTA / bVisitors : 0;

const MIN_SESSIONS = 100;
const MIN_LEAD = 0.05;
const hasEnoughData = aVisitors >= MIN_SESSIONS && bVisitors >= MIN_SESSIONS;
const convDiff = Math.abs(aConv - bConv);
const hasWinner = hasEnoughData && convDiff >= MIN_LEAD;
const winner = aConv >= bConv ? "A" : "B";
const winnerHeadline = winner === "A"
  ? "You don't know what you don't have."
  : "Getting data from real people is exhausting.";
---

<Layout title="A/B Results — emify admin">
  <main class="min-h-screen bg-background py-12 px-4">
    <div class="mx-auto max-w-4xl">

      <div class="mb-10">
        <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-2">emify admin</div>
        <h1 class="text-3xl font-bold text-foreground">A/B Test Results</h1>
        <p class="text-muted-foreground mt-2">
          Variant A: "The Blank Page Problem" · Variant B: "The Chasing Problem"
        </p>
        {!kvAvailable && (
          <div class="mt-4 rounded-lg bg-amber-100 border border-amber-300 px-4 py-3 text-sm text-amber-800">
            KV namespace not available — running without Cloudflare Workers binding. No live data to display.
          </div>
        )}
      </div>

      {/* Summary cards */}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
        {[
          {
            variant: "A",
            headline: "The Blank Page Problem",
            visitors: aVisitors,
            scroll: aScroll,
            cta: aCTA,
            conv: aConv,
          },
          {
            variant: "B",
            headline: "The Chasing Problem",
            visitors: bVisitors,
            scroll: bScroll,
            cta: bCTA,
            conv: bConv,
          },
        ].map(({ variant, headline, visitors, scroll, cta, conv }) => (
          <div class={`rounded-2xl border p-6 ${hasWinner && winner === variant ? "border-primary bg-primary/5" : "bg-card"}`}>
            <div class="flex items-center justify-between mb-4">
              <div>
                <div class="text-xs font-bold text-primary uppercase tracking-wide mb-0.5">Variant {variant}</div>
                <div class="text-sm font-semibold text-foreground">"{headline}"</div>
              </div>
              {hasWinner && winner === variant && (
                <div class="rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">Winner</div>
              )}
            </div>
            <div class="space-y-3">
              <div class="flex justify-between text-sm">
                <span class="text-muted-foreground">Total visitors</span>
                <span class="font-semibold text-foreground">{visitors}</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-muted-foreground">Scrolled past 70%</span>
                <span class="font-semibold text-foreground">{scroll} ({pct(scroll, visitors)})</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-muted-foreground">CTA clicks</span>
                <span class="font-semibold text-foreground">{cta} ({pct(cta, visitors)})</span>
              </div>
              <div class="pt-2 border-t flex justify-between">
                <span class="text-sm font-semibold text-foreground">Conversion rate</span>
                <span class={`text-base font-bold ${hasWinner && winner === variant ? "text-primary" : "text-foreground"}`}>
                  {pct(cta, visitors)}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Winner recommendation */}
      <div class={`rounded-2xl border p-6 mb-10 ${hasWinner ? "border-primary bg-primary/5" : "bg-muted/30"}`}>
        <h2 class="text-lg font-bold text-foreground mb-2">Recommendation</h2>
        {!hasEnoughData ? (
          <p class="text-muted-foreground text-sm">
            Not enough data yet. You need at least {MIN_SESSIONS} sessions per variant before a winner
            can be declared. Currently: Variant A has {aVisitors} sessions, Variant B has {bVisitors}.
          </p>
        ) : !hasWinner ? (
          <p class="text-muted-foreground text-sm">
            Both variants have sufficient data ({aVisitors} vs {bVisitors} sessions) but the
            conversion rate difference ({(convDiff * 100).toFixed(1)}%) is below the 5% threshold
            required to declare a winner. Continue running the test.
          </p>
        ) : (
          <div>
            <p class="text-foreground font-medium mb-2">
              Variant {winner} is the winner — "{winnerHeadline}"
            </p>
            <p class="text-muted-foreground text-sm">
              Variant {winner} achieved a {pct(winner === "A" ? aCTA : bCTA, winner === "A" ? aVisitors : bVisitors)} conversion
              rate vs {pct(winner === "A" ? bCTA : aCTA, winner === "A" ? bVisitors : aVisitors)} for the
              other variant — a {(convDiff * 100).toFixed(1)} percentage point lead across{" "}
              {winner === "A" ? aVisitors : bVisitors} sessions. Promote this variant to 100% of traffic.
            </p>
          </div>
        )}
      </div>

      {/* Raw totals */}
      <div class="rounded-xl border bg-card overflow-hidden">
        <div class="px-5 py-4 border-b">
          <h3 class="text-sm font-semibold text-foreground">Summary table</h3>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-muted/40">
            <tr>
              <th class="text-left px-5 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wide">Metric</th>
              <th class="text-right px-5 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wide">Variant A</th>
              <th class="text-right px-5 py-3 text-xs font-semibold text-muted-foreground uppercase tracking-wide">Variant B</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <tr>
              <td class="px-5 py-3 text-muted-foreground">Total visitors</td>
              <td class="px-5 py-3 text-right font-medium">{aVisitors}</td>
              <td class="px-5 py-3 text-right font-medium">{bVisitors}</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-muted-foreground">Scroll depth (70%+)</td>
              <td class="px-5 py-3 text-right font-medium">{aScroll} ({pct(aScroll, aVisitors)})</td>
              <td class="px-5 py-3 text-right font-medium">{bScroll} ({pct(bScroll, bVisitors)})</td>
            </tr>
            <tr>
              <td class="px-5 py-3 text-muted-foreground">CTA clicks</td>
              <td class="px-5 py-3 text-right font-medium">{aCTA} ({pct(aCTA, aVisitors)})</td>
              <td class="px-5 py-3 text-right font-medium">{bCTA} ({pct(bCTA, bVisitors)})</td>
            </tr>
            <tr class="font-semibold">
              <td class="px-5 py-3">Conversion rate</td>
              <td class={`px-5 py-3 text-right ${hasWinner && winner === "A" ? "text-primary" : ""}`}>{pct(aCTA, aVisitors)}</td>
              <td class={`px-5 py-3 text-right ${hasWinner && winner === "B" ? "text-primary" : ""}`}>{pct(bCTA, bVisitors)}</td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </main>
</Layout>
