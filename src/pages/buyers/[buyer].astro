---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import BuyerPage from '../../components/BuyerPage';
import buyers from '../../../data/buyers.json';
import supplierTypes from '../../../data/supplier-types.json';

export async function getStaticPaths() {
  return Object.values(buyers).map((buyer: any) => {
    const relatedSuppliers = (buyer.supplierTypes ?? []).map((slug: string) => {
      const sup = (supplierTypes as any)[slug];
      return sup ? { slug, name: sup.name } : null;
    }).filter(Boolean);
    return {
      params: { buyer: buyer.slug },
      props: { buyer, relatedSuppliers },
    };
  });
}

const { buyer, relatedSuppliers } = Astro.props;

const description = `Outsourced sustainability reporting for ${buyer.name} suppliers. We respond to their data requests for a flat monthly fee — no demos, no consultancy charges.`;

const faqSchema = buyer.faqs && buyer.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: buyer.faqs.map((f: any) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : undefined;
---

<Layout
  title={`Supplying ${buyer.name}? Sustainability data requests, handled | Emify`}
  description={description}
  structuredData={faqSchema}
>
  <Navbar client:load />
  <main><BuyerPage data={buyer} relatedSuppliers={relatedSuppliers} client:load /></main>
  <Footer client:load />
</Layout>
